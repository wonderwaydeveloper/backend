# .env.testing file :

# Run migrations for test database
# php artisan migrate:fresh --seed --env=testing

# # Or run specific test suites
# php artisan test --testsuite=Unit
# php artisan test --testsuite=Feature

# # Run specific test file
# php artisan test tests/Feature/AuthTest.php

# # Run specific test method
# php artisan test tests/Feature/AuthTest.php --filter=test_user_can_register_with_email


# =============================================
# BASIC APP CONFIGURATION
# =============================================
APP_NAME="Wonder Way Pictures"
APP_ENV=local
APP_KEY=base64:Gyq2g6LNUvrSimjVMDqdJe8D5K7qARDhDwgt4PBy57k=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=fa
APP_FALLBACK_LOCALE=fa
APP_FAKER_LOCALE=fa_IR


# =============================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=social_network_test
DB_USERNAME=postgres 
# DB_PASSWORD=password 

# =============================================
# REDIS CONFIGURATION
# =============================================
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================
# CACHE & SESSION CONFIGURATION
# =============================================
CACHE_DRIVER=array
SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# =============================================
# QUEUE CONFIGURATION
# =============================================
QUEUE_CONNECTION=redis

# =============================================
# FILE STORAGE
# =============================================
FILESYSTEM_DISK=public

# =============================================
# MAIL CONFIGURATION (برای فعال‌سازی ایمیل)
# =============================================
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=9dd28eb71586cb
MAIL_PASSWORD=fbda50c20a66ea
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@wonderwaypictures.com"
MAIL_FROM_NAME="${APP_NAME}"

# Looking to send emails in production? Check out our Email API/SMTP product!


# =============================================
# SANCTUM CONFIGURATION (برای احراز هویت API)
# =============================================
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1

# =============================================
# SOCIALITE CONFIGURATION (اگر نیاز دارید)
# =============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/google/callback"

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/api/auth/facebook/callback"

# =============================================
# SMS SERVICE (اگر نیاز دارید)
# =============================================
KAVENEGAR_API_KEY=
KAVENEGAR_SENDER=

# =============================================
# APPLICATION SPECIFIC SETTINGS
# =============================================
ENABLE_PHONE_AUTH=true
ENABLE_SOCIAL_AUTH=true
MAX_POSTS_PER_DAY=50
MAX_FILE_UPLOAD_SIZE=10240
